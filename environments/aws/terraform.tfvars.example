# ─────────────────────────────────────────────────────────────────────────────
# AWS SOC Terraform — Example Variable Values
#
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored to prevent committing secrets.
#
# Prerequisites:
#   1. AWS CLI installed and configured: aws configure
#   2. Verify auth: aws sts get-caller-identity
#   3. Set a billing alert before deploying:
#      AWS Console → Billing → Budgets → Create budget ($5/month recommended)
# ─────────────────────────────────────────────────────────────────────────────

# AWS region. us-east-1 has the broadest Free Tier availability.
region = "us-east-1"

# Short prefix for all resource names (lowercase, 2-6 chars).
prefix = "soc"

# Environment label applied as a tag to every resource.
environment = "lab"

# ── Network ──────────────────────────────────────────────────────────────────

vpc_cidr               = "10.0.0.0/16"
management_subnet_cidr = "10.0.1.0/24"
workload_subnet_cidr   = "10.0.2.0/24"

# ── Compute ──────────────────────────────────────────────────────────────────

# t3.micro is Free Tier eligible (750 hrs/month for 12 months).
instance_type = "t3.micro"

# Generate with: ssh-keygen -t rsa -b 4096 -f ~/.ssh/aws_soc_key
# Then paste the contents of ~/.ssh/aws_soc_key.pub below.
# Note: primary access is via SSM Session Manager — no inbound SSH port is open.
admin_ssh_public_key = "ssh-rsa AAAA..."

# ── Monitoring ───────────────────────────────────────────────────────────────

# 30 days keeps storage within the CloudWatch Free Tier (5 GB/month).
log_retention_days = 30

# ── Extra Tags ───────────────────────────────────────────────────────────────

tags = {
  owner = "your-github-username"
}
